generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INTERVIEWER
  CANDIDATE
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id              String             @id @default(cuid())
  username        String             @unique
  email           String             @unique
  passwordHash    String
  role            Role               @default(CANDIDATE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  refreshTokens   RefreshToken[]
  rooms           InterviewRoom[]
  participations  RoomParticipant[]
  submissions     Submission[]
  drafts          CodeDraft[]
  contestParticipations ContestParticipant[]

  @@map("users")
}

model Problem {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String
  difficulty  String
  starterCode Json
  constraints Json?
  examples    Json?
  createdAt   DateTime     @default(now())
  submissions Submission[]
  tags        ProblemTag[]
  drafts      CodeDraft[]
  contestProblems ContestProblem[]
  testCases   TestCase[]

  @@map("problems")
}

model ProblemTag {
  id       String    @id @default(cuid())
  name     String    @unique
  problems Problem[]

  @@map("problem_tags")
}

model TestCase {
  id             String   @id @default(cuid())
  problemId      String
  input          String   @db.Text
  expectedOutput String   @db.Text
  isHidden       Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

model CodeDraft {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  language  String
  code      String
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId, language])
  @@map("code_drafts")
}

model Submission {
  id              String           @id @default(cuid())
  userId          String
  problemId       String?
  roomId          String?
  contestId       String?
  language        String
  sourceCode      String
  status          SubmissionStatus @default(PENDING)
  verdict         String?
  stdout          String?
  stderr          String?
  executionTimeMs Int?
  memory          String?
  passedTestCases Int?
  totalTestCases  Int?
  failedTestCase  Json?
  createdAt       DateTime         @default(now())
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem         Problem?         @relation(fields: [problemId], references: [id], onDelete: SetNull)
  room            InterviewRoom?   @relation(fields: [roomId], references: [id], onDelete: SetNull)
  contest         Contest?         @relation(fields: [contestId], references: [id], onDelete: SetNull)
  contestSubmission ContestSubmission?
  feedback        SubmissionFeedback?

  @@map("submissions")
}

model SubmissionFeedback {
  id                 String     @id @default(cuid())
  submissionId       String     @unique
  summary            String
  strengths          Json
  weaknesses         Json
  optimizations      Json
  complexityEstimate String
  readabilityScore   Int
  createdAt          DateTime   @default(now())

  submission         Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_feedbacks")
}

model InterviewRoom {
  id           String             @id @default(cuid())
  title        String
  createdBy    String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  host         User               @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  participants RoomParticipant[]
  snapshots    RoomCodeSnapshot[]
  submissions  Submission[]
  sessions     InterviewSession[]

  @@map("interview_rooms")
}

model RoomParticipant {
  id       String        @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime      @default(now())
  room     InterviewRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_participants")
}

model RoomCodeSnapshot {
  id       String        @id @default(cuid())
  roomId   String
  language String
  code     String
  savedAt  DateTime      @default(now())
  room     InterviewRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_code_snapshots")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Contest {
  id          String               @id @default(cuid())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime             @default(now())
  problems    ContestProblem[]
  participants ContestParticipant[]
  submissions Submission[]
  contestSubmissions ContestSubmission[]

  @@map("contests")
}

model ContestProblem {
  id        String   @id @default(cuid())
  contestId String
  problemId String
  points    Int
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([contestId, problemId])
  @@map("contest_problems")
}

model ContestParticipant {
  id         String   @id @default(cuid())
  contestId  String
  userId     String
  score      Int      @default(0)
  penalty    Int      @default(0)
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contest    Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@map("contest_participants")
}

model ContestSubmission {
  id            String     @id @default(cuid())
  contestId     String
  submissionId  String     @unique
  problemId     String
  pointsAwarded Int        @default(0)
  penaltyTime   Int        @default(0)
  createdAt     DateTime   @default(now())
  contest       Contest    @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("contest_submissions")
}

model InterviewSession {
  id        String   @id @default(cuid())
  roomId    String
  room      InterviewRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  startedAt DateTime @default(now())
  endedAt   DateTime?
  createdAt DateTime @default(now())
  events    SessionEvent[]

  @@map("interview_sessions")
}

model SessionEvent {
  id         String   @id @default(cuid())
  sessionId  String
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String?
  eventType  String
  payload    Json
  createdAt  DateTime @default(now())

  @@map("session_events")
}
